---
// en/Ingredients.astro - Zephyr ingredients with tabs (English)
// Tabular display
---

<section class="ingredients" id="ingredients">
  <div class="container">
    
    <div class="section-header">
      <span class="section-label">The Science</span>
      <h2>Clinically supported ingredients</h2>
      <p class="section-description">
        Every ingredient has been carefully selected based on scientific research and clinical studies.
      </p>
    </div>
    
    <!-- Tabs -->
    <div class="tabs-container">
      <div class="tabs">
        <button class="tab-btn active" data-tab="preventive">
          Preventive Formula
        </button>
        <button class="tab-btn" data-tab="recovery">
          Recovery Formula
        </button>
      </div>
      
      <!-- Tab Content: Preventive -->
      <div class="tab-content active" id="tab-preventive">
        <div class="ingredients-grid preventive-grid">
          <div class="ingredient-item">
            <span class="ingredient-name">L-cysteine</span>
            <span class="ingredient-dose">1000 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Prickly pear extract (5:1)</span>
            <span class="ingredient-dose">240 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Myricetin</span>
            <span class="ingredient-dose">50 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Taurine</span>
            <span class="ingredient-dose">1000 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Lactobacillus plantarum</span>
            <span class="ingredient-dose">5 billion CFU</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Vitamin B6</span>
            <span class="ingredient-dose">10 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Vitamin C</span>
            <span class="ingredient-dose">1200 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Magnesium</span>
            <span class="ingredient-dose">150 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Potassium</span>
            <span class="ingredient-dose">296 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Sodium</span>
            <span class="ingredient-dose">144 mg</span>
          </div>
        </div>
      </div>
      
      <!-- Tab Content: Recovery -->
      <div class="tab-content" id="tab-recovery">
        <div class="ingredients-grid">
          <div class="ingredient-item">
            <span class="ingredient-name">Glutathione</span>
            <span class="ingredient-dose">500 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">L-alanyl-L-glutamine</span>
            <span class="ingredient-dose">1000 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Milk thistle</span>
            <span class="ingredient-dose">150 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Myricetin</span>
            <span class="ingredient-dose">50 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Phosphatidylcholine</span>
            <span class="ingredient-dose">30 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Vitamin B1</span>
            <span class="ingredient-dose">90 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Vitamin C</span>
            <span class="ingredient-dose">800 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Magnesium</span>
            <span class="ingredient-dose">150 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Potassium</span>
            <span class="ingredient-dose">296 mg</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Sodium</span>
            <span class="ingredient-dose">144 mg</span>
          </div>
        </div>
      </div>
      
    </div>
    
  </div>
</section>

<style>
  .ingredients {
    padding: 6rem 1.5rem;
    background: #1A1A1A;
    background-size: cover;
    background-position: center right;
    color: white;
    position: relative;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .section-label {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #8B3A96;
    margin-bottom: 1rem;
  }
  
  .section-header h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: white;
    margin-bottom: 1rem;
  }
  
  .section-description {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: 600px;
    margin: 0 auto;
  }
  
    /* Tabs */
  .tabs-container {
    max-width: 1000px;
    margin: 0 auto;
  }
  
  .tabs {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 3rem;
  }
  
  .tab-btn {
    padding: 1rem 2rem;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .tab-btn:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.3);
    color: white;
  }
  
  .tab-btn.active {
    border-color: rgba(255, 255, 255, 0.4);
    color: white;
  }
  
  .tab-btn.active[data-tab="preventive"] {
    background: #E879F9;
    border-color: #E879F9;
    color: #1A1A1A;
  }
  
  .tab-btn.active[data-tab="recovery"] {
    background: #00ecfdff;
    border-color: #00ecfdff;
    color: #1A1A1A;
  }

  
  /* Tab Content */
  .tab-content {
    display: none;
    animation: fadeIn 0.3s ease;
  }
  
  .tab-content.active {
    display: block;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  /* Ingredients Grid - Táblázatos */
  .ingredients-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  
  @media (max-width: 968px) {
    .ingredients-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 480px) {
    .ingredients-grid {
      grid-template-columns: 1fr;
    }
  }
  
  .ingredient-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    transition: all 0.3s ease;
  }
  
  .ingredient-item:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.15);
  }
  
  .ingredient-name {
    font-size: 0.95rem;
    font-weight: 500;
    color: white;
    line-height: 1.3;
  }
  
  .ingredient-dose {
    font-size: 0.875rem;
    font-weight: 600;
    color: #00ecfdff;
  }
  
  /* Preventive tab doses get neon purple */
  .preventive-grid .ingredient-dose {
    color: #E879F9;
  }
</style>

<script>
  // Tab functionality - plain JS (no optional chaining, no template literals with ?.)
  var ingredientSection = document.querySelector('.ingredients');
  
  if (ingredientSection) {
    var tabBtns = ingredientSection.querySelectorAll('.tab-btn');
    for (var i = 0; i < tabBtns.length; i++) {
      tabBtns[i].addEventListener('click', function() {
        var btn = this;
        var target = btn.getAttribute('data-tab');
        
        // Update buttons
        var allBtns = ingredientSection.querySelectorAll('.tab-btn');
        for (var j = 0; j < allBtns.length; j++) {
          allBtns[j].classList.remove('active');
        }
        btn.classList.add('active');
        
        // Update content
        var allContents = ingredientSection.querySelectorAll('.tab-content');
        for (var k = 0; k < allContents.length; k++) {
          allContents[k].classList.remove('active');
        }
        var targetContent = ingredientSection.querySelector('#tab-' + target);
        if (targetContent) {
          targetContent.classList.add('active');
        }
      });
    }
  }
</script>
