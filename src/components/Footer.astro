---
// en/Hero.astro - Zephyr homepage hero section (English)
// Orbit animation + 3D product video
---

<section class="hero" id="hero">
  <div class="hero-container">
    
    <!-- Bal oldal: Tartalom -->
    <div class="hero-content">
      <h1 class="sr-only">Zephyr — Premium dietary supplement against hangovers, with a dual formula</h1>
      
      <h2 class="hero-title">
        <span class="line-1">Two formulas.</span> <span class="line-2">One night.</span><br>
        <span class="gradient-text">Zero drama.</span>
      </h2>
      
      <p class="hero-description">
        Zephyr's dual formula provides evening preparation and morning recovery for those rough nights.
        One Preventive, one Recovery — double protection. 
        Developed by pharmacists, backed by science, for an easier morning.
      </p>
      
      <div class="hero-cta">
        <a href="/en/shop#shop" class="btn-primary">
          Shop Now
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="/en/how-it-works" class="btn-secondary">
          How it Works
        </a>
      </div>
    </div>
    
    <!-- Jobb oldal: Orbit animáció + Termék -->
    <div class="hero-visual">
      <div class="orbit-container">
        
        <!-- Orbit pályák -->
        <div class="orbit-track orbit-track-1"></div>
        <div class="orbit-track orbit-track-2"></div>
        <div class="orbit-track orbit-track-3"></div>
        
        <!-- Keringő elemek -->
        <div class="orbit-item orbit-1">
          <div class="orbit-dot purple"></div>
        </div>
        <div class="orbit-item orbit-2">
          <div class="orbit-dot blue"></div>
        </div>
        <div class="orbit-item orbit-3">
          <div class="orbit-dot purple-light"></div>
        </div>
        
        <!-- Központi termék -->
        <div class="hero-product">          
            <img src="/images/Zephyr_doboz_3D_latvany.webp" alt="Zephyr: evening and morning support during alcohol consumption">
      
        </div>
        
      </div>
    </div>
    
  </div>
</section>

<style is:global>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 1.5rem 4rem;
    background:  #fffffb;
    overflow: hidden;
  }
  
  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
    align-items: center;
  }
  
  .hero-content {
    min-width: 0;
  }
  
  .hero-visual {
    min-width: 0;
  }
  
  @media (max-width: 968px) {
    .hero {
      padding: 6rem 1.5rem 2rem;
      min-height: auto;
    }
    
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 1rem;
    }
  }
  
  /* Content */
  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 600;
    line-height: 1.15;
    color: #1A1A1A;
    margin-bottom: 1.5rem;
  }
  
  /* Mobile: each sentence on its own line */
  @media (max-width: 968px) {
    .hero-title .line-1::after {
      content: '';
      display: block;
    }
  }
  
  .gradient-text {
    background: linear-gradient(135deg, #6D2077, #003B5C);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .hero-description {
    font-size: 1.125rem;
    color: #4A4A4A;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 520px;
  }
  
  @media (max-width: 968px) {
    .hero-description {
      max-width: 100%;
    }
  }
  
  .hero-cta {
    display: flex;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  
  @media (max-width: 968px) {
    .hero-cta {
      justify-content: center;
      flex-wrap: wrap;
    }
  }
  
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    min-width: 200px;
    background: #6D2077;
    color: white;
    font-weight: 600;
    border-radius: 50px;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  
  .btn-primary:hover {
    background: #4A1552;
    transform: translateY(-2px);
  }
  
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2rem;
    min-width: 200px;
    background: #003B5C;
    color: white;
    font-weight: 600;
    border-radius: 50px;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  
  .btn-secondary:hover {
    background: #002A42;
    transform: translateY(-2px);
  }
  
  /* Visual / Orbit */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: visible;
    position: relative;
    height: 580px;
  }
  
  @media (max-width: 1024px) {
    .hero-visual {
      height: 450px;
    }
  }
  
  @media (max-width: 968px) {
    .hero-visual {
      height: 380px;
    }
  }
  
  @media (max-width: 480px) {
    .hero-visual {
      height: 340px;
    }
  }
  
  .orbit-container {
    position: absolute;
    width: 700px;
    height: 700px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  
  @media (max-width: 1024px) {
    .orbit-container {
      width: 550px;
      height: 550px;
    }
  }
  
  @media (max-width: 968px) {
    .orbit-container {
      width: 400px;
      height: 400px;
    }
  }
  
  /* Orbit tracks */
  .orbit-track {
    position: absolute;
    border: 1px solid rgba(109, 32, 119, 0.15);
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  
  .orbit-track-1 {
    width: 580px;
    height: 580px;
  }
  
  .orbit-track-2 {
    width: 700px;
    height: 700px;
    border-color: rgba(0, 59, 92, 0.15);
  }
  
  .orbit-track-3 {
    width: 460px;
    height: 460px;
    border-color: rgba(109, 32, 119, 0.1);
  }
  
  @media (max-width: 1024px) {
    .orbit-track-1 { width: 370px; height: 370px; }
    .orbit-track-2 { width: 460px; height: 460px; }
    .orbit-track-3 { width: 290px; height: 290px; }
  }
  
  @media (max-width: 968px) {
    .orbit-track-1 { width: 270px; height: 270px; }
    .orbit-track-2 { width: 340px; height: 340px; }
    .orbit-track-3 { width: 210px; height: 210px; }
  }
  
  /* Orbiting items */
  .orbit-item {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
  }
  
  .orbit-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    box-shadow: 0 0 20px currentColor;
    margin: -6px 0 0 -6px;
  }
  
  .orbit-dot.purple {
    background: #6D2077;
    color: rgba(109, 32, 119, 0.5);
  }
  
  .orbit-dot.blue {
    background: #003B5C;
    color: rgba(0, 59, 92, 0.5);
  }
  
  .orbit-dot.purple-light {
    background: #8B3A96;
    color: rgba(139, 58, 150, 0.5);
  }
  
  .orbit-1 {
    animation: orbit-1 20s linear infinite;
  }
  
  .orbit-2 {
    animation: orbit-2 25s linear infinite reverse;
  }
  
  .orbit-3 {
    animation: orbit-3 30s linear infinite;
  }
  
  @keyframes orbit-1 {
    from { transform: rotate(0deg) translateX(290px) rotate(0deg); }
    to { transform: rotate(360deg) translateX(290px) rotate(-360deg); }
  }
  
  @keyframes orbit-2 {
    from { transform: rotate(0deg) translateX(350px) rotate(0deg); }
    to { transform: rotate(360deg) translateX(350px) rotate(-360deg); }
  }
  
  @keyframes orbit-3 {
    from { transform: rotate(0deg) translateX(230px) rotate(0deg); }
    to { transform: rotate(360deg) translateX(230px) rotate(-360deg); }
  }
  
  @media (max-width: 1024px) {
    @keyframes orbit-1 {
      from { transform: rotate(0deg) translateX(185px) rotate(0deg); }
      to { transform: rotate(360deg) translateX(185px) rotate(-360deg); }
    }
    
    @keyframes orbit-2 {
      from { transform: rotate(0deg) translateX(230px) rotate(0deg); }
      to { transform: rotate(360deg) translateX(230px) rotate(-360deg); }
    }
    
    @keyframes orbit-3 {
      from { transform: rotate(0deg) translateX(145px) rotate(0deg); }
      to { transform: rotate(360deg) translateX(145px) rotate(-360deg); }
    }
  }
  
  @media (max-width: 968px) {
    @keyframes orbit-1 {
      from { transform: rotate(0deg) translateX(135px) rotate(0deg); }
      to { transform: rotate(360deg) translateX(135px) rotate(-360deg); }
    }
    
    @keyframes orbit-2 {
      from { transform: rotate(0deg) translateX(170px) rotate(0deg); }
      to { transform: rotate(360deg) translateX(170px) rotate(-360deg); }
    }
    
    @keyframes orbit-3 {
      from { transform: rotate(0deg) translateX(105px) rotate(0deg); }
      to { transform: rotate(360deg) translateX(105px) rotate(-360deg); }
    }
  }
  
  /* Central product */
  .hero-product {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 300px;
    height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  @media (max-width: 1024px) {
    .hero-product {
      width: 300px;
      height: 300px;
    }
  }
  
  @media (max-width: 968px) {
    .hero-product {
      width: 200px;
      height: 200px;
    }
  }
  
  .hero-product video,
  .hero-product img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
</style>---
// Footer.astro - Zephyr footer
// i18n: lang prop ("hu" default | "en")
interface Props {
  lang?: 'hu' | 'en';
}

const { lang = 'hu' } = Astro.props;

// ── Lokalizált szövegek ───────────────────────────────────
const dict = {
  hu: {
    newsletterTitle: 'Iratkozz fel hírlevelünkre',
    newsletterDesc: 'Exkluzív ajánlatok, új termékek és hasznos tippek — közvetlenül a postaládádba.',
    newsletterPlaceholder: 'Email címed',
    newsletterBtn: 'Feliratkozom',
    tagline: 'Két bölcs döntés. Egy jobb reggel.',
    colProducts: 'Termékek',
    colInfo: 'Információ',
    colContact: 'Kapcsolat',
    productsPreventive: 'Preventive',
    productsRecovery: 'Recovery',
    productsPackages: 'Csomagok',
    howItWorks: 'Hogyan működik',
    ingredients: 'Összetevők',
    faq: 'GYIK',
    copy: '© 2026 Toplexa Kft. Minden jog fenntartva.',
    credit: 'Weboldal & webáruház készítés',
    privacy: 'Adatvédelem',
    terms: 'Felhasználási feltételek',
    productsAnchor: '/#products',
    shopUrl: '/vasarlas#shop',
    howItWorksUrl: '/hogyan-mukodik',
    ingredientsAnchor: '/#ingredients',
    faqAnchor: '/#faq',
    privacyUrl: '/adatvedelem',
    termsUrl: '/aszf',
    newsletterAlert: 'Köszönjük a feliratkozást!',
  },
  en: {
    newsletterTitle: 'Subscribe to Our Newsletter',
    newsletterDesc: 'Exclusive offers, new products, and useful tips — delivered straight to your inbox.',
    newsletterPlaceholder: 'Your email address',
    newsletterBtn: 'Subscribe',
    tagline: 'Two wise choices. One better morning.',
    colProducts: 'Products',
    colInfo: 'Information',
    colContact: 'Contact',
    productsPreventive: 'Preventive',
    productsRecovery: 'Recovery',
    productsPackages: 'Packages',
    howItWorks: 'How it Works',
    ingredients: 'Ingredients',
    faq: 'FAQ',
    copy: '© 2026 Toplexa Kft. All rights reserved.',
    credit: 'Website & e-commerce by',
    privacy: 'Privacy Policy',
    terms: 'Terms & Conditions',
    productsAnchor: '/en#products',
    shopUrl: '/en/shop#shop',
    howItWorksUrl: '/en/how-it-works',
    ingredientsAnchor: '/en#ingredients',
    faqAnchor: '/en#faq',
    privacyUrl: '/adatvedelem',
    termsUrl: '/aszf',
    newsletterAlert: 'Thank you for subscribing!',
  },
};

const t = dict[lang];
---

<footer class="footer">
  <div class="container">
    
    <!-- Newsletter -->
    <div class="newsletter">
      <h3>{t.newsletterTitle}</h3>
      <p>{t.newsletterDesc}</p>
      <form class="newsletter-form" id="newsletter-form" data-success-msg={t.newsletterAlert}>
        <input 
          type="email" 
          placeholder={t.newsletterPlaceholder} 
          required 
          class="newsletter-input"
        />
        <button type="submit" class="newsletter-btn">{t.newsletterBtn}</button>
      </form>
    </div>
    
    <div class="footer-divider"></div>
    
    <!-- Footer Content -->
    <div class="footer-content">
      
      <!-- Logo -->
      <div class="footer-brand">
        <span class="footer-logo">Zephyr</span>
        <p class="footer-tagline">{t.tagline}</p>
      </div>
      
      <!-- Links -->
      <nav class="footer-nav">
        <div class="footer-col">
          <h4>{t.colProducts}</h4>
          <a href={t.productsAnchor}>{t.productsPreventive}</a>
          <a href={t.productsAnchor}>{t.productsRecovery}</a>
          <a href={t.shopUrl}>{t.productsPackages}</a>
        </div>
        <div class="footer-col">
          <h4>{t.colInfo}</h4>
          <a href={t.howItWorksUrl}>{t.howItWorks}</a>
          <a href={t.ingredientsAnchor}>{t.ingredients}</a>
          <a href={t.faqAnchor}>{t.faq}</a>
        </div>
        <div class="footer-col">
          <h4>{t.colContact}</h4>
          <a href="mailto:info@zephyr.hu">info@zephyr.hu</a>
          <a href="#">Instagram</a>
          <a href="#">Facebook</a>
        </div>
      </nav>
      
    </div>
    
    <div class="footer-divider"></div>
    
    <!-- Bottom -->
    <div class="footer-bottom">
      <div class="footer-copy-wrap">
        <p class="footer-copy">{t.copy}</p>
        <p class="footer-credit">
          <a href="https://conendigital.hu" target="_blank" rel="noopener">{t.credit}</a> — Conen Digital
        </p>
      </div>
      <div class="footer-legal">
        <a href={t.privacyUrl}>{t.privacy}</a>
        <a href={t.termsUrl}>{t.terms}</a>
      </div>
    </div>
    
  </div>
</footer>

<style>
  .footer {
    padding: 4rem 1.5rem 2rem;
    background: #1A1A1A;
    color: white;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  /* Newsletter */
  .newsletter {
    text-align: center;
    max-width: 500px;
    margin: 0 auto 3rem;
  }
  
  .newsletter h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.75rem;
    font-weight: 400;
    margin-bottom: 0.75rem;
  }
  
  .newsletter p {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 1.5rem;
  }
  
  .newsletter-form {
    display: flex;
    gap: 0.75rem;
  }
  
  @media (max-width: 480px) {
    .newsletter-form {
      flex-direction: column;
    }
  }
  
  .newsletter-input {
    flex: 1;
    padding: 1rem 1.25rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50px;
    color: white;
    font-size: 1rem;
    outline: none;
    transition: all 0.2s ease;
  }
  
  .newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }
  
  .newsletter-input:focus {
    border-color: #6D2077;
    background: rgba(255, 255, 255, 0.15);
  }
  
  .newsletter-btn {
    padding: 1rem 2rem;
    background: #6D2077;
    color: white;
    font-weight: 600;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }
  
  .newsletter-btn:hover {
    background: #8B3A96;
  }
  
  /* Divider */
  .footer-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 2rem 0;
  }
  
  /* Content */
  .footer-content {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
  }
  
  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }
  }
  
  /* Brand */
  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 400;
    background: linear-gradient(135deg, #8B3A96, #0A5A85);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .footer-tagline {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 0.5rem;
  }
  
  /* Nav */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  
  /* Mobilon is 3 oszlop egymás mellett — szűkebb gap és balra igazítás,
     hogy a rövid linkek elférjenek a legkisebb kijelzőkön is. */
  @media (max-width: 480px) {
    .footer-nav {
      gap: 0.75rem;
      text-align: left;
    }
    
    .footer-col h4 {
      font-size: 0.95rem;
      margin-bottom: 0.75rem;
    }
    
    .footer-col a {
      font-size: 0.8rem;
      margin-bottom: 0.6rem;
      word-break: break-word;
    }
  }
  
  .footer-col h4 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.125rem;
    font-weight: 400;
    margin-bottom: 1rem;
    color: white;
  }
  
  .footer-col a {
    display: block;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    margin-bottom: 0.75rem;
    transition: color 0.2s ease;
  }
  
  .footer-col a:hover {
    color: #8B3A96;
  }
  
  /* Bottom */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  @media (max-width: 640px) {
    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }
  
  .footer-copy {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
  }
  
  .footer-copy-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  
  .footer-credit {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    margin: 0;
  }
  
  .footer-credit a {
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  
  .footer-credit a:hover {
    color: #8B3A96;
  }
  
  .footer-legal {
    display: flex;
    gap: 1.5rem;
  }
  
  .footer-legal a {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  
  .footer-legal a:hover {
    color: rgba(255, 255, 255, 0.7);
  }
</style>

<script>
  var form = document.getElementById('newsletter-form');
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var successMsg = form.getAttribute('data-success-msg') || 'Thank you!';
      // TODO: Integrate with email service (Klaviyo, etc.)
      alert(successMsg);
      form.reset();
    });
  }
</script>
