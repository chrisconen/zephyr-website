---
// Ingredients.astro - Zephyr összetevők tab-okkal
// Táblázatos megjelenítés az index.html alapján
---

<section class="ingredients" id="ingredients">
  <div class="container">
    
    <div class="section-header">
      <span class="section-label">A Tudomány</span>
      <h2>Tudományosan megalapozott összetevők</h2>
      <p class="section-description">
        Gyógyszerészek által kifejlesztett, gondosan összeválogatott összetevők — 
        mindegyik az Európai Élelmiszerbiztonsági Hatóság (EFSA) által elismert listákon szerepel.
      </p>
    </div>
    
    <!-- Tabs -->
    <div class="tabs-container">
      <div class="tabs">
        <button class="tab-btn active" data-tab="preventive">
          Preventive Formula
        </button>
        <button class="tab-btn" data-tab="recovery">
          Recovery Formula
        </button>
      </div>
      
      <!-- Tab Content: Preventive -->
      <div class="tab-content active" id="tab-preventive">
        <div class="ingredients-grid">
          <div class="ingredient-item">
            <span class="ingredient-name">C-vitamin</span>
            <span class="ingredient-dose">1200 mg</span>
            <span class="ingredient-desc">Antioxidáns és immunrendszer támogatás</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">L-cisztein</span>
            <span class="ingredient-dose">1000 mg</span>
            <span class="ingredient-desc">Aminosav, amely közvetlenül részt vesz az acetaldehid lebontásában</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Taurin</span>
            <span class="ingredient-dose">1000 mg</span>
            <span class="ingredient-desc">Erős antioxidáns, védi a sejteket az oxidatív stressztől</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Kálium</span>
            <span class="ingredient-dose">296 mg</span>
            <span class="ingredient-desc">Elektrolit a dehidratáció megelőzésére</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Fügekaktusz kivonat (5:1)</span>
            <span class="ingredient-dose">240 mg</span>
            <span class="ingredient-desc">Klinikai vizsgálatokban bizonyított hatás a másnaposság tüneteire</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Magnézium</span>
            <span class="ingredient-dose">150 mg</span>
            <span class="ingredient-desc">Elektrolit az izomfunkció és idegrendszer támogatására</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Nátrium</span>
            <span class="ingredient-dose">144 mg</span>
            <span class="ingredient-desc">A folyadékegyensúly és elektrolit-szint fenntartása</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Miricetin</span>
            <span class="ingredient-dose">50 mg</span>
            <span class="ingredient-desc">Erős antioxidáns flavonoid, támogatja a belső egyensúlyt</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">B6-vitamin</span>
            <span class="ingredient-dose">10 mg</span>
            <span class="ingredient-desc">Az energia-anyagcsere és az aminosav-feldolgozás támogatása</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Lactobacillus plantarum</span>
            <span class="ingredient-dose">5 milliárd CFU</span>
            <span class="ingredient-desc">Probiotikum az emésztőrendszer és a bélflóra egyensúlyának támogatására</span>
          </div>
        </div>
      </div>
      
      <!-- Tab Content: Recovery -->
      <div class="tab-content" id="tab-recovery">
        <div class="ingredients-grid">
          <div class="ingredient-item">
            <span class="ingredient-name">L-alanil-L-glutamin</span>
            <span class="ingredient-dose">1000 mg</span>
            <span class="ingredient-desc">Gyors felszívódású aminosav a regenerálódáshoz és rapid hidratáláshoz</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">C-vitamin</span>
            <span class="ingredient-dose">800 mg</span>
            <span class="ingredient-desc">Antioxidáns és immunrendszer támogatás</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Glutation</span>
            <span class="ingredient-dose">500 mg</span>
            <span class="ingredient-desc">A "mester antioxidáns" — kulcsszerepet játszik a méregtelenítésben</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Kálium</span>
            <span class="ingredient-dose">296 mg</span>
            <span class="ingredient-desc">A folyadékegyensúly helyreállítása</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Máriatövis</span>
            <span class="ingredient-dose">150 mg</span>
            <span class="ingredient-desc">Évszázadok óta használt gyógynövény a máj támogatására (silymarin)</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Magnézium</span>
            <span class="ingredient-dose">150 mg</span>
            <span class="ingredient-desc">Az ásványi anyagok pótlása és az izomfunkció támogatása</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Nátrium</span>
            <span class="ingredient-dose">144 mg</span>
            <span class="ingredient-desc">A folyadékegyensúly és elektrolit-szint helyreállítása</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">B1-vitamin</span>
            <span class="ingredient-dose">90 mg</span>
            <span class="ingredient-desc">Az energia-anyagcsere támogatása — az alkohol csökkenti a B-vitamin szintet</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Miricetin</span>
            <span class="ingredient-dose">50 mg</span>
            <span class="ingredient-desc">Erős antioxidáns flavonoid a szervezet egyensúlyának támogatására</span>
          </div>
          <div class="ingredient-item">
            <span class="ingredient-name">Foszfatidilkolin</span>
            <span class="ingredient-dose">30 mg</span>
            <span class="ingredient-desc">Segíti a szervezet egyensúlyát és a sejt-regenerációt</span>
          </div>
        </div>
      </div>
      
    </div>
    
  </div>
</section>

<style>
  .ingredients {
    padding: 6rem 1.5rem;
    background: #1A1A1A;
    background-size: cover;
    background-position: center right;
    color: white;
    position: relative;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .section-label {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #8B3A96;
    margin-bottom: 1rem;
  }
  
  .section-header h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: white;
    margin-bottom: 1rem;
  }
  
  .section-description {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: 600px;
    margin: 0 auto;
  }
  
  /* Tabs */
  .tabs-container {
    max-width: 1000px;
    margin: 0 auto;
  }
  
  .tabs {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 3rem;
  }
  
  .tab-btn {
    padding: 1rem 2rem;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .tab-btn:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.3);
    color: white;
  }
  
  .tab-btn.active {
    background: white;
    border-color: white;
    color: #1A1A1A;
  }
  
  /* Tab Content */
  .tab-content {
    display: none;
    animation: fadeIn 0.3s ease;
  }
  
  .tab-content.active {
    display: block;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  /* Ingredients Grid - Táblázatos */
  .ingredients-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  
  @media (max-width: 968px) {
    .ingredients-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 480px) {
    .ingredients-grid {
      grid-template-columns: 1fr;
    }
  }
  
  .ingredient-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    transition: all 0.3s ease;
  }
  
  .ingredient-item:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.15);
  }
  
  .ingredient-name {
    font-size: 0.95rem;
    font-weight: 500;
    color: white;
    line-height: 1.3;
  }
  
  .ingredient-dose {
    font-size: 0.875rem;
    font-weight: 600;
    color: #00ecfdff;
  }
  
  .ingredient-desc {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.4;
  }
</style>

<script>
  // Tab functionality
  const ingredientSection = document.querySelector('.ingredients');
  
  ingredientSection?.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;
      
      // Update buttons
      ingredientSection.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      // Update content
      ingredientSection.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      ingredientSection.querySelector(`#tab-${target}`)?.classList.add('active');
    });
  });
</script>
