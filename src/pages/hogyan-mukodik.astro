      margin-bottom: 0;
      padding-bottom: 0;
      border-bottom: none;
    }
    
    .progress-nav { display: none; }
  }
  
  /* Content Side */
  .content-side {
    position: relative;
    height: 60vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  
  /* Progress Nav */
  .progress-nav {
    position: absolute;
    left: -70px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  
  @media (max-width: 1200px) {
    .progress-nav { display: none; }
  }
  
  .progress-track {
    width: 3px;
    height: 160px;
    background: rgba(255,255,255,0.1);
    border-radius: 3px;
    position: relative;
  }
  
  .progress-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 25%;
    background: linear-gradient(180deg, #8B3A96, #0EA5E9);
    border-radius: 3px;
    transition: height 0.5s ease;
    box-shadow: 0 0 15px rgba(139, 58, 150, 0.5);
  }
  
  .progress-dots {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }
  
  .progress-dot {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    border: 2px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.4);
    font-size: 0.75rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.4s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .progress-dot:hover {
    border-color: rgba(139, 58, 150, 0.5);
    color: rgba(255,255,255,0.7);
  }
  
  .progress-dot.active {
    background: linear-gradient(135deg, #8B3A96, #0A5A85);
    border-color: transparent;
    color: white;
    box-shadow: 0 0 20px rgba(139, 58, 150, 0.5);
  }
  
  /* Feature Items */
  .feature-item {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
  }
  
  .feature-item.active {
    opacity: 1;
    pointer-events: auto;
  }
  
  .feature-label {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 1.25rem;
    padding: 0.5rem 1rem;
    border-radius: 30px;
    background: rgba(255,255,255,0.05);
  }
  
  .feature-label::before {
    content: '';
    width: 10px;
    height: 10px;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  
  .danger-label { color: #EF4444; }
  .danger-label::before { background: #EF4444; box-shadow: 0 0 10px #EF4444; }
  
  .warning-label { color: #FBBF24; }
  .warning-label::before { background: #FBBF24; box-shadow: 0 0 10px #FBBF24; }
  
  .preventive-label { color: #A855F7; }
  .preventive-label::before { background: #A855F7; box-shadow: 0 0 10px #A855F7; }
  
  .recovery-label { color: #0EA5E9; }
  .recovery-label::before { background: #0EA5E9; box-shadow: 0 0 10px #0EA5E9; }
  
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }
  
  .feature-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: white;
    margin-bottom: 1.5rem;
    line-height: 1.15;
