---
// hogyan-mukodik.astro - Zephyr "Hogyan működik" aloldal
// GSAP ScrollTrigger + EPIC SVG animációk
// Pixella-level: flowing particles, glow paths, circuit board style
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Hogyan működik" description="Tudományosan megalapozott dupla formula a másnaposság ellen.">
  
  <Header />
  
  <main class="how-it-works-page">
    
    <!-- Hero Section -->
    <section class="hiw-hero">
      <div class="container">
        <span class="section-label">A Tudomány</span>
        <h1>Hogyan működik a <span class="gradient-text">Zephyr</span>?</h1>
        <p class="hero-subtitle">
          A Zephyr dupla formulája esti és reggeli támogatást nyújt alkoholfogyasztás során.
          Prémium. Célzott. Tudományosan megalapozott.
        </p>
        <div class="scroll-hint">
          <span>Görgess a tudományért</span>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 5v14M5 12l7 7 7-7"/>
          </svg>
        </div>
      </div>
    </section>
    
    <!-- ═══════════════════════════════════════════════════════════
         SCROLL SECTION - Pinned 4-step animation
         ═══════════════════════════════════════════════════════════ -->
    <section class="scroll-section" id="the-basics">
      <div class="scroll-container">
        
        <!-- Left Side - Text Content -->
        <div class="content-side">
          
          <!-- Progress Indicator -->
          <div class="progress-nav">
            <div class="progress-track">
              <div class="progress-fill"></div>
            </div>
            <div class="progress-dots">
              <button class="progress-dot active" data-step="1">01</button>
              <button class="progress-dot" data-step="2">02</button>
              <button class="progress-dot" data-step="3">03</button>
              <button class="progress-dot" data-step="4">04</button>
            </div>
          </div>
          
          <!-- Step 1: Acetaldehid -->
          <div class="feature-item active" data-step="acetaldehyde">
            <div class="feature-label danger-label">01 — A Probléma</div>
            <h2 class="feature-title">Az alkohol acetaldehidet termel</h2>
            <p class="feature-description">
              Amikor alkoholt fogyasztunk, a szervezet megkezdi annak lebontását. 
              Ennek során <strong>acetaldehid</strong> keletkezik — egy toxikus melléktermék, 
              amely felelős a másnapos tünetek nagy részéért.
            </p>
            <div class="feature-stats">
              <div class="stat">
                <span class="stat-value" id="stat-toxic">10×</span>
                <span class="stat-label">mérgezőbb mint az alkohol</span>
              </div>
              <div class="stat">
                <span class="stat-value" id="stat-time">6-8 óra</span>
                <span class="stat-label">lebontási idő</span>
              </div>
            </div>
          </div>
          
          <!-- Step 2: Dehidratáció -->
          <div class="feature-item" data-step="dehydration">
            <div class="feature-label warning-label">02 — A Folyamat</div>
            <h2 class="feature-title">A szervezet elveszíti az egyensúlyt</h2>
            <p class="feature-description">
              Az alkohol diuretikus hatású — fokozza a vizelettermelést, ami 
              <strong>dehidratációhoz</strong> vezet. Eközben fontos vitaminokat és ásványi 
              anyagokat veszítünk.
            </p>
            <div class="feature-stats">
              <div class="stat">
                <span class="stat-value" id="stat-bvit">-50%</span>
                <span class="stat-label">B-vitamin szint</span>
              </div>
              <div class="stat">
                <span class="stat-value" id="stat-fluid">4×</span>
                <span class="stat-label">több folyadékvesztés</span>
              </div>
            </div>
          </div>
          
          <!-- Step 3: Preventive -->
          <div class="feature-item" data-step="preventive">
            <div class="feature-label preventive-label">03 — Preventive</div>
            <h2 class="feature-title">Felkészítjük a szervezetet</h2>
            <p class="feature-description">
              A <strong>Preventive formula</strong> ivás előtt támogatja a máj természetes 
              méregtelenítő folyamatait. L-cisztein, miricetin és fügekaktusz-kivonat segít az acetaldehid 
              lebontásában, míg a Lactobacillus plantarum probiotikum az emésztést támogatja.
            </p>
            <div class="feature-stats">
              <div class="stat">
                <span class="stat-value" id="stat-lcys">1000mg</span>
                <span class="stat-label">L-cisztein</span>
              </div>
              <div class="stat">
                <span class="stat-value" id="stat-ofi">240mg</span>
                <span class="stat-label">Fügekaktusz</span>
              </div>
            </div>
          </div>
          
          <!-- Step 4: Recovery -->
          <div class="feature-item" data-step="recovery">
            <div class="feature-label recovery-label">04 — Recovery</div>
            <h2 class="feature-title">Helyreállítjuk az egyensúlyt</h2>
            <p class="feature-description">
              A <strong>Recovery formula</strong> az este után vagy reggel segít a regenerálódásban. 
              Glutation és máriatövis támogatják a máj tisztulását, míg az L-alanil-L-glutamin 
              és foszfatidilkolin segíti a rapid hidratálást és a szervezet egyensúlyát.
            </p>
            <div class="feature-stats">
              <div class="stat">
                <span class="stat-value" id="stat-gsh">500mg</span>
                <span class="stat-label">Glutation</span>
              </div>
              <div class="stat">
                <span class="stat-value" id="stat-b1">90mg</span>
                <span class="stat-label">B1-vitamin</span>
              </div>
            </div>
          </div>
          
        </div>
        
        <!-- Right Side - EPIC Visual Animations -->
        <div class="visual-side">
          <div class="visual-container">
            
            <!-- ═══════════════════════════════════════
                 VISUAL 1: TOXIN CIRCUIT - Data flow style
                 ═══════════════════════════════════════ -->
            <div class="feature-visual active" data-step="acetaldehyde">
              <div class="visual-wrapper">
                <svg class="epic-svg" viewBox="0 0 500 500">
                  <defs>
                    <!-- Glow filters -->
                    <filter id="redGlow" x="-50%" y="-50%" width="200%" height="200%">
                      <feGaussianBlur stdDeviation="8" result="blur"/>
                      <feMerge>
                        <feMergeNode in="blur"/>
                        <feMergeNode in="SourceGraphic"/>
                      </feMerge>
                    </filter>
                    <filter id="strongRedGlow" x="-100%" y="-100%" width="300%" height="300%">
                      <feGaussianBlur stdDeviation="15" result="blur"/>
                      <feMerge>
                        <feMergeNode in="blur"/>
                        <feMergeNode in="blur"/>
                        <feMergeNode in="SourceGraphic"/>
                      </feMerge>
                    </filter>
                    
                    <!-- Gradient for flowing pulse -->
                    <linearGradient id="toxinPulseGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                      <stop offset="0%" stop-color="#DC2626" stop-opacity="0"/>
                      <stop offset="50%" stop-color="#EF4444" stop-opacity="1"/>
                      <stop offset="100%" stop-color="#DC2626" stop-opacity="0"/>
                    </linearGradient>
                    
                    <!-- Radial danger glow -->
                    <radialGradient id="dangerRadial" cx="50%" cy="50%" r="50%">
                      <stop offset="0%" stop-color="#DC2626" stop-opacity="0.4"/>
                      <stop offset="70%" stop-color="#DC2626" stop-opacity="0.1"/>
                      <stop offset="100%" stop-color="#DC2626" stop-opacity="0"/>
                    </radialGradient>
                  </defs>
                  
                  <!-- Background danger pulse -->
                  <circle cx="250" cy="250" r="200" fill="url(#dangerRadial)" class="danger-bg-pulse"/>
                  
                  <!-- Circuit paths - Liver to body -->
                  <g class="circuit-paths">
                    <!-- Main circuit lines -->
                    <path id="toxinPath1" class="circuit-line" d="M100,250 Q150,250 180,200 Q210,150 250,150" fill="none" stroke="#3a3a4a" stroke-width="3"/>
                    <path id="toxinPath2" class="circuit-line" d="M100,250 Q150,250 200,250 Q250,250 300,250" fill="none" stroke="#3a3a4a" stroke-width="3"/>
                    <path id="toxinPath3" class="circuit-line" d="M100,250 Q150,250 180,300 Q210,350 250,350" fill="none" stroke="#3a3a4a" stroke-width="3"/>
                    <path id="toxinPath4" class="circuit-line" d="M250,150 Q320,150 360,180 Q400,210 400,250" fill="none" stroke="#3a3a4a" stroke-width="3"/>
                    <path id="toxinPath5" class="circuit-line" d="M250,350 Q320,350 360,320 Q400,290 400,250" fill="none" stroke="#3a3a4a" stroke-width="3"/>
                    
                    <!-- Flowing pulse lines -->
                    <path id="toxinPulse1" class="pulse-line" d="M100,250 Q150,250 180,200 Q210,150 250,150" fill="none" stroke="url(#toxinPulseGrad)" stroke-width="5" stroke-linecap="round"/>
                    <path id="toxinPulse2" class="pulse-line" d="M100,250 Q150,250 200,250 Q250,250 300,250" fill="none" stroke="url(#toxinPulseGrad)" stroke-width="5" stroke-linecap="round"/>
                    <path id="toxinPulse3" class="pulse-line" d="M100,250 Q150,250 180,300 Q210,350 250,350" fill="none" stroke="url(#toxinPulseGrad)" stroke-width="5" stroke-linecap="round"/>
                  </g>
                  
                  <!-- Central Liver chip -->
                  <g class="liver-chip" transform="translate(100, 250)">
                    <rect x="-45" y="-45" width="90" height="90" rx="16" fill="#2a2a3a" stroke="#4a4a5a" stroke-width="2"/>
                    <rect class="chip-glow" x="-45" y="-45" width="90" height="90" rx="16" fill="none" stroke="#DC2626" stroke-width="2" opacity="0"/>
                    <!-- Liver icon -->
                    <text x="0" y="8" text-anchor="middle" fill="#8a8a9a" font-size="32">🫀</text>
                    <text x="0" y="32" text-anchor="middle" fill="#6a6a7a" font-size="10" font-weight="600">MÁJ</text>
                  </g>
                  
                  <!-- Toxin molecule nodes -->
                  <g class="toxin-nodes">
                    <!-- Node 1 - Top -->
                    <g class="toxin-node" id="toxinNode1" transform="translate(250, 150)">
                      <circle r="35" fill="#1a1a24" stroke="#3a3a4a" stroke-width="2"/>
                      <circle class="node-glow" r="35" fill="none" stroke="#DC2626" stroke-width="3" opacity="0"/>
                      <circle cx="0" cy="-8" r="12" fill="#DC2626" class="atom-c"/>
                      <circle cx="-15" cy="10" r="8" fill="#EF4444" class="atom-h"/>
                      <circle cx="15" cy="10" r="8" fill="#EF4444" class="atom-h"/>
                      <text x="0" y="-4" text-anchor="middle" fill="white" font-size="8" font-weight="bold">C</text>
                    </g>
                    
                    <!-- Node 2 - Center -->
                    <g class="toxin-node" id="toxinNode2" transform="translate(300, 250)">
                      <circle r="40" fill="#1a1a24" stroke="#3a3a4a" stroke-width="2"/>
                      <circle class="node-glow" r="40" fill="none" stroke="#DC2626" stroke-width="3" opacity="0"/>
                      <text x="0" y="6" text-anchor="middle" fill="#DC2626" font-size="11" font-weight="bold">ACETALDEHID</text>
                    </g>
                    
                    <!-- Node 3 - Bottom -->
                    <g class="toxin-node" id="toxinNode3" transform="translate(250, 350)">
                      <circle r="35" fill="#1a1a24" stroke="#3a3a4a" stroke-width="2"/>
                      <circle class="node-glow" r="35" fill="none" stroke="#DC2626" stroke-width="3" opacity="0"/>
                      <circle cx="-12" cy="-5" r="10" fill="#F87171" class="atom-o"/>
                      <circle cx="12" cy="-5" r="10" fill="#F87171" class="atom-o"/>
                      <circle cx="0" cy="12" r="8" fill="#DC2626"/>
                      <text x="-12" y="-1" text-anchor="middle" fill="white" font-size="7" font-weight="bold">O</text>
                      <text x="12" y="-1" text-anchor="middle" fill="white" font-size="7" font-weight="bold">O</text>
                    </g>
                    
                    <!-- Body target -->
                    <g class="body-target" transform="translate(400, 250)">
                      <circle r="50" fill="#1a1a24" stroke="#3a3a4a" stroke-width="2"/>
                      <circle class="target-pulse" r="50" fill="none" stroke="#DC2626" stroke-width="2" opacity="0"/>
                      <text x="0" y="-5" text-anchor="middle" fill="#DC2626" font-size="28">⚠️</text>
                      <text x="0" y="20" text-anchor="middle" fill="#8a8a9a" font-size="9" font-weight="600">TOXIKUS</text>
                    </g>
                  </g>
                  
                  <!-- Floating danger particles -->
                  <g class="danger-particles">
                    <circle class="d-particle" cx="150" cy="180" r="3" fill="#DC2626"/>
                    <circle class="d-particle" cx="180" cy="320" r="4" fill="#EF4444"/>
                    <circle class="d-particle" cx="320" cy="180" r="3" fill="#DC2626"/>
                    <circle class="d-particle" cx="350" cy="320" r="4" fill="#EF4444"/>
                    <circle class="d-particle" cx="280" cy="200" r="2" fill="#F87171"/>
                    <circle class="d-particle" cx="220" cy="300" r="3" fill="#DC2626"/>
                  </g>
                </svg>
                
                <!-- Status badge -->
                <div class="visual-badge danger">
                  <span class="badge-dot"></span>
                  <span>Toxin termelés aktív</span>
                </div>
              </div>
            </div>
            
            <!-- ═══════════════════════════════════════
                 VISUAL 2: DEHYDRATION - Water drain effect
                 ═══════════════════════════════════════ -->
            <div class="feature-visual" data-step="dehydration">
              <div class="visual-wrapper">
                <svg class="epic-svg" viewBox="0 0 500 500">
                  <defs>
                    <filter id="blueGlow" x="-50%" y="-50%" width="200%" height="200%">
                      <feGaussianBlur stdDeviation="6" result="blur"/>
                      <feMerge>
                        <feMergeNode in="blur"/>
                        <feMergeNode in="SourceGraphic"/>
                      </feMerge>
                    </filter>
                    <linearGradient id="waterGradient" x1="0%" y1="0%" x2="0%" y2="100%">
                      <stop offset="0%" stop-color="#3B82F6"/>
                      <stop offset="100%" stop-color="#1D4ED8"/>
                    </linearGradient>
                    <linearGradient id="drainPulse" x1="0%" y1="0%" x2="0%" y2="100%">
                      <stop offset="0%" stop-color="#FBBF24" stop-opacity="0"/>
                      <stop offset="50%" stop-color="#F59E0B" stop-opacity="1"/>
                      <stop offset="100%" stop-color="#FBBF24" stop-opacity="0"/>
                    </linearGradient>
                    <clipPath id="bodyClipPath">
                      <path d="M180,100 L320,100 L340,400 L160,400 Z"/>
                    </clipPath>
                  </defs>
                  
                  <!-- Body container -->
                  <g class="body-container">
                    <!-- Body outline -->
                    <path d="M180,100 L320,100 L340,400 L160,400 Z" fill="none" stroke="#4a4a5a" stroke-width="4" stroke-linejoin="round"/>
                    
                    <!-- Water inside body (animated level) -->
                    <g clip-path="url(#bodyClipPath)">
                      <rect id="waterLevel" x="160" y="200" width="180" height="200" fill="url(#waterGradient)" opacity="0.7"/>
                      <!-- Wave animation -->
                      <path id="waterWave" d="M160,200 Q200,180 250,200 T340,200 L340,400 L160,400 Z" fill="url(#waterGradient)" opacity="0.5"/>
                    </g>
                    
                    <!-- Drain pipes -->
                    <g class="drain-pipes">
                      <path id="drainPath1" d="M180,300 Q120,300 100,350 L100,420" fill="none" stroke="#4a4a5a" stroke-width="3"/>
                      <path id="drainPath2" d="M320,300 Q380,300 400,350 L400,420" fill="none" stroke="#4a4a5a" stroke-width="3"/>
                      
                      <!-- Flowing drain pulses -->
                      <path id="drainPulse1" d="M180,300 Q120,300 100,350 L100,420" fill="none" stroke="url(#drainPulse)" stroke-width="6" stroke-linecap="round"/>
                      <path id="drainPulse2" d="M320,300 Q380,300 400,350 L400,420" fill="none" stroke="url(#drainPulse)" stroke-width="6" stroke-linecap="round"/>
                    </g>
                  </g>
                  
                  <!-- Escaping nutrient bubbles -->
                  <g class="nutrient-bubbles">
                    <!-- Left side nutrients -->
                    <g class="nutrient-bubble nb1" transform="translate(80, 350)">
                      <circle r="25" fill="rgba(251, 191, 36, 0.2)" stroke="#FBBF24" stroke-width="2"/>
                      <text y="5" text-anchor="middle" fill="#FBBF24" font-size="11" font-weight="bold">B₆</text>
                    </g>
                    <g class="nutrient-bubble nb2" transform="translate(100, 420)">
                      <circle r="22" fill="rgba(139, 92, 246, 0.2)" stroke="#8B5CF6" stroke-width="2"/>
                      <text y="5" text-anchor="middle" fill="#8B5CF6" font-size="11" font-weight="bold">Mg</text>
                    </g>
                    
                    <!-- Right side nutrients -->
                    <g class="nutrient-bubble nb3" transform="translate(420, 350)">
                      <circle r="23" fill="rgba(34, 197, 94, 0.2)" stroke="#22C55E" stroke-width="2"/>
                      <text y="5" text-anchor="middle" fill="#22C55E" font-size="11" font-weight="bold">K</text>
                    </g>
                    <g class="nutrient-bubble nb4" transform="translate(400, 420)">
                      <circle r="20" fill="rgba(251, 191, 36, 0.2)" stroke="#FBBF24" stroke-width="2"/>
                      <text y="5" text-anchor="middle" fill="#FBBF24" font-size="11" font-weight="bold">B₁₂</text>
                    </g>
                  </g>
                  
                  <!-- Water droplets escaping -->
                  <g class="water-drops">
                    <circle class="w-drop" cx="130" cy="320" r="6" fill="#3B82F6" filter="url(#blueGlow)"/>
                    <circle class="w-drop" cx="370" cy="330" r="5" fill="#60A5FA"/>
                    <circle class="w-drop" cx="110" cy="380" r="4" fill="#3B82F6"/>
                    <circle class="w-drop" cx="390" cy="390" r="6" fill="#60A5FA" filter="url(#blueGlow)"/>
                    <circle class="w-drop" cx="95" cy="440" r="5" fill="#3B82F6"/>
                    <circle class="w-drop" cx="405" cy="450" r="4" fill="#60A5FA"/>
                  </g>
                  
                  <!-- Percentage indicator -->
                  <g transform="translate(250, 70)">
                    <rect x="-50" y="-20" width="100" height="40" rx="20" fill="rgba(251, 191, 36, 0.15)" stroke="#FBBF24" stroke-width="1"/>
                    <text id="dehydrationPercent" x="0" y="7" text-anchor="middle" fill="#FBBF24" font-size="16" font-weight="bold">-50%</text>
                  </g>
                </svg>
                
                <div class="visual-badge warning">
                  <span class="badge-dot"></span>
                  <span>Dehidratáció folyamatban</span>
                </div>
              </div>
            </div>
            
            <!-- ═══════════════════════════════════════
                 VISUAL 3: PREVENTIVE - Shield activation
                 ═══════════════════════════════════════ -->
            <div class="feature-visual" data-step="preventive">
              <div class="visual-wrapper">
                <svg class="epic-svg" viewBox="0 0 500 500">
                  <defs>
                    <filter id="purpleGlow" x="-50%" y="-50%" width="200%" height="200%">
                      <feGaussianBlur stdDeviation="10" result="blur"/>
                      <feMerge>
                        <feMergeNode in="blur"/>
                        <feMergeNode in="blur"/>
                        <feMergeNode in="SourceGraphic"/>
                      </feMerge>
                    </filter>
                    <linearGradient id="shieldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                      <stop offset="0%" stop-color="#6D2077"/>
                      <stop offset="50%" stop-color="#8B3A96"/>
                      <stop offset="100%" stop-color="#A855F7"/>
                    </linearGradient>
                    <linearGradient id="shieldPulseGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                      <stop offset="0%" stop-color="#A855F7" stop-opacity="0"/>
                      <stop offset="50%" stop-color="#C084FC" stop-opacity="1"/>
                      <stop offset="100%" stop-color="#A855F7" stop-opacity="0"/>
                    </linearGradient>
                    <radialGradient id="shieldRadial" cx="50%" cy="50%" r="50%">
                      <stop offset="0%" stop-color="#8B3A96" stop-opacity="0.3"/>
                      <stop offset="100%" stop-color="#8B3A96" stop-opacity="0"/>
                    </radialGradient>
                  </defs>
                  
                  <!-- Background energy field -->
                  <circle cx="250" cy="250" r="220" fill="url(#shieldRadial)" class="shield-energy-bg"/>
                  
                  <!-- Orbital rings -->
                  <g class="orbital-system">
                    <circle cx="250" cy="250" r="180" fill="none" stroke="rgba(139, 58, 150, 0.2)" stroke-width="1" stroke-dasharray="10,5" class="orbit-ring o1"/>
                    <circle cx="250" cy="250" r="140" fill="none" stroke="rgba(139, 58, 150, 0.3)" stroke-width="1" stroke-dasharray="8,4" class="orbit-ring o2"/>
                    <circle cx="250" cy="250" r="100" fill="none" stroke="rgba(139, 58, 150, 0.4)" stroke-width="1" class="orbit-ring o3"/>
                  </g>
                  
                  <!-- Shield shape -->
                  <g class="shield-main" transform="translate(250, 250)">
                    <!-- Outer glow shield -->
                    <path class="shield-glow-path" d="M0,-100 L80,-65 L80,40 Q80,95 0,115 Q-80,95 -80,40 L-80,-65 Z" 
                          fill="none" stroke="url(#shieldGrad)" stroke-width="6" filter="url(#purpleGlow)" opacity="0.5"/>
                    
                    <!-- Main shield -->
                    <path class="shield-fill" d="M0,-90 L70,-58 L70,35 Q70,85 0,103 Q-70,85 -70,35 L-70,-58 Z" 
                          fill="url(#shieldGrad)" opacity="0.9"/>
                    
                    <!-- Shield inner border -->
                    <path d="M0,-75 L55,-48 L55,28 Q55,70 0,85 Q-55,70 -55,28 L-55,-48 Z" 
                          fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2"/>
                    
                    <!-- Animated checkmark -->
                    <path id="shieldCheck" d="M-30,5 L-8,28 L35,-25" 
                          fill="none" stroke="white" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
                    
                    <!-- Shield pulse rings -->
                    <circle class="shield-pulse-ring spr1" r="70" fill="none" stroke="#A855F7" stroke-width="2"/>
                    <circle class="shield-pulse-ring spr2" r="85" fill="none" stroke="#8B3A96" stroke-width="1"/>
                    <circle class="shield-pulse-ring spr3" r="100" fill="none" stroke="#6D2077" stroke-width="1"/>
                  </g>
                  
                  <!-- Orbiting ingredient nodes -->
                  <g class="ingredient-nodes">
                    <!-- L-Cysteine -->
                    <g class="ing-node ing1">
                      <circle cx="250" cy="70" r="30" fill="#1a1a24" stroke="#8B3A96" stroke-width="2"/>
                      <circle class="ing-glow" cx="250" cy="70" r="30" fill="none" stroke="#A855F7" stroke-width="3" filter="url(#purpleGlow)"/>
                      <text x="250" y="65" text-anchor="middle" fill="#C084FC" font-size="9" font-weight="bold">L-CYS</text>
                      <text x="250" y="80" text-anchor="middle" fill="#8a8a9a" font-size="8">1000mg</text>
                    </g>
                    
                    <!-- Taurin -->
                    <g class="ing-node ing2">
                      <circle cx="400" cy="300" r="28" fill="#1a1a24" stroke="#8B3A96" stroke-width="2"/>
                      <circle class="ing-glow" cx="400" cy="300" r="28" fill="none" stroke="#A855F7" stroke-width="3" filter="url(#purpleGlow)"/>
                      <text x="400" y="295" text-anchor="middle" fill="#C084FC" font-size="9" font-weight="bold">TAU</text>
                      <text x="400" y="310" text-anchor="middle" fill="#8a8a9a" font-size="8">500mg</text>
                    </g>
                    
                    <!-- Fügekaktusz -->
                    <g class="ing-node ing3">
                      <circle cx="100" cy="300" r="28" fill="#1a1a24" stroke="#8B3A96" stroke-width="2"/>
