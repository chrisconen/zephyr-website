<!-- GSAP -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/MotionPathPlugin.min.js"></script>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  if (typeof gsap === 'undefined') return;
  
  gsap.registerPlugin(ScrollTrigger, MotionPathPlugin);
  
  var steps = ['acetaldehyde', 'dehydration', 'preventive', 'recovery'];
  var currentStep = 0;
  
  var scrollSection = document.querySelector('.scroll-section');
  var featureItems = document.querySelectorAll('.feature-item');
  var featureVisuals = document.querySelectorAll('.feature-visual');
  var progressDots = document.querySelectorAll('.progress-dot');
  var progressFill = document.querySelector('.progress-fill');
  
  // Create flowing pulse animations for toxin paths
  function createToxinPulseAnimations() {
    var pulses = ['#toxinPulse1', '#toxinPulse2', '#toxinPulse3'];
    
    pulses.forEach(function(selector, index) {
      var pulse = document.querySelector(selector);
      if (!pulse) return;
      
      var length = pulse.getTotalLength();
      gsap.set(pulse, { 
        strokeDasharray: length,
        strokeDashoffset: length
      });
      
      gsap.to(pulse, {
        strokeDashoffset: -length,
        duration: 2,
        repeat: -1,
        ease: 'none',
        delay: index * 0.4
      });
    });
  }
  
  // Create node glow animations
  function createNodeGlowAnimations() {
    gsap.to('.node-glow', {
      opacity: 0.8,
      duration: 1,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut',
      stagger: 0.3
    });
    
    gsap.to('.chip-glow', {
      opacity: 0.6,
      duration: 1.5,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut'
    });
    
    gsap.to('.target-pulse', {
      opacity: 0.5,
      scale: 1.15,
      duration: 1,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut',
      transformOrigin: 'center'
    });
  }
  
  // Create drain pulse animations
  function createDrainAnimations() {
    ['#drainPulse1', '#drainPulse2'].forEach(function(selector, index) {
      var pulse = document.querySelector(selector);
      if (!pulse) return;
      
      var length = pulse.getTotalLength();
      gsap.set(pulse, {
        strokeDasharray: 40 + ' ' + length,
        strokeDashoffset: -length
      });
      
      gsap.to(pulse, {
        strokeDashoffset: length,
        duration: 1.5,
        repeat: -1,
        ease: 'none',
        delay: index * 0.5
      });
    });
  }
  
  // Create shield flow dot animations
  function createShieldFlowAnimations() {
    ['flowPath1', 'flowPath2', 'flowPath3'].forEach(function(pathId, index) {
      var path = document.getElementById(pathId);
      var dot = document.getElementById('flowDot' + (index + 1));
      if (!path || !dot) return;
      
      // Make visible and animate
      gsap.set(dot, { opacity: 1 });
      gsap.to(dot, {
        motionPath: {
          path: '#' + pathId,
          align: '#' + pathId,
          alignOrigin: [0.5, 0.5]
        },
        duration: 1.5,
        repeat: -1,
        ease: 'none',
        delay: index * 0.5
      });
    });
    
    // Ingredient glow
    gsap.to('.ing-glow', {
      opacity: 0.8,
      duration: 1.2,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut',
      stagger: 0.4
    });
  }
  
  // Create recovery stream animations
  function createRecoveryStreamAnimations() {
    [1, 2, 3, 4].forEach(function(num) {
      var path = document.getElementById('streamPath' + num);
      var dot = document.getElementById('streamDot' + num);
      if (!path || !dot) return;
      
      // Make visible and animate
      gsap.set(dot, { opacity: 1 });
      gsap.to(dot, {
        motionPath: {
          path: '#streamPath' + num,
          align: '#streamPath' + num,
          alignOrigin: [0.5, 0.5]
        },
        duration: 2,
        repeat: -1,
        ease: 'power1.inOut',
        delay: (num - 1) * 0.5
      });
    });
  }
  
  // Initialize all animations
  createToxinPulseAnimations();
  createNodeGlowAnimations();
  createDrainAnimations();
  createShieldFlowAnimations();
  createRecoveryStreamAnimations();
  
  // ScrollTrigger
  ScrollTrigger.create({
    trigger: scrollSection,
    start: 'top top',
    end: 'bottom bottom',
    scrub: 0.5,
    onUpdate: function(self) {
      var progress = self.progress;
      var stepIndex = Math.min(Math.floor(progress * steps.length), steps.length - 1);
      
      if (progressFill) {
        progressFill.style.height = (progress * 100) + '%';
      }
      
      if (stepIndex !== currentStep) {
        updateStep(stepIndex);
        currentStep = stepIndex;
      }
    }
  });
  
  function updateStep(index) {
    featureItems.forEach(function(item, i) {
      item.classList.toggle('active', i === index);
    });
    
    featureVisuals.forEach(function(visual, i) {
      visual.classList.toggle('active', i === index);
    });
    
    progressDots.forEach(function(dot, i) {
      dot.classList.toggle('active', i === index);
    });
  }
  
  // Progress dot click
  progressDots.forEach(function(dot, i) {
    dot.addEventListener('click', function() {
      var scrollStart = scrollSection.offsetTop;
      var scrollHeight = scrollSection.offsetHeight - window.innerHeight;
      var targetScroll = scrollStart + (scrollHeight * (i / steps.length)) + 100;
      
      window.scrollTo({ top: targetScroll, behavior: 'smooth' });
    });
  });
  
  // Hero animation
  gsap.from('.hiw-hero h1, .hiw-hero .hero-subtitle', {
    opacity: 0,
    y: 40,
    duration: 1.2,
    stagger: 0.2,
    ease: 'power3.out'
  });
  
  ScrollTrigger.refresh();
  console.log('Zephyr EPIC animations initialized');
});
</script>
