    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
  }
  
  /* ═══════════════════════════════════════════
     VISUAL SIDE
     ═══════════════════════════════════════════ */
  .visual-side {
    position: relative;
    height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .visual-container {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  
  .feature-visual {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: scale(0.9);
    transition: opacity 0.8s ease, transform 0.8s ease;
    pointer-events: none;
    overflow: hidden;
  }
  
  .feature-visual.active {
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
  }
  
  .visual-wrapper {
    position: relative;
    width: 100%;
    max-width: 500px;
    overflow: hidden;
  }
  
  .epic-svg {
    width: 100%;
    height: auto;
    overflow: visible;
    display: block;
  }
  
  /* Visual badges */
  .visual-badge {
    position: absolute;
    bottom: 10%;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.5rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    backdrop-filter: blur(10px);
  }
  
  .badge-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    animation: pulse 1.5s infinite;
  }
  
  .visual-badge.danger {
    background: rgba(220, 38, 38, 0.2);
    border: 1px solid rgba(220, 38, 38, 0.4);
    color: #EF4444;
  }
  .visual-badge.danger .badge-dot { background: #EF4444; }
  
  .visual-badge.warning {
    background: rgba(251, 191, 36, 0.15);
    border: 1px solid rgba(251, 191, 36, 0.4);
    color: #FBBF24;
  }
  .visual-badge.warning .badge-dot { background: #FBBF24; }
  
  .visual-badge.preventive {
    background: rgba(139, 58, 150, 0.2);
    border: 1px solid rgba(139, 58, 150, 0.4);
    color: #A855F7;
  }
  .visual-badge.preventive .badge-dot { background: #A855F7; }
  
  .visual-badge.recovery {
    background: rgba(14, 165, 233, 0.2);
    border: 1px solid rgba(14, 165, 233, 0.4);
    color: #0EA5E9;
  }
  .visual-badge.recovery .badge-dot { background: #0EA5E9; }
  
  /* ═══════════════════════════════════════════
     SVG ANIMATIONS
     ═══════════════════════════════════════════ */
  
  /* Danger background pulse */
  .danger-bg-pulse {
    animation: dangerPulse 3s ease-in-out infinite;
  }
  @keyframes dangerPulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.05); }
  }
  
  /* Floating particles */
  .d-particle {
    animation: floatParticle 4s ease-in-out infinite;
  }
  .d-particle:nth-child(1) { animation-delay: 0s; }
  .d-particle:nth-child(2) { animation-delay: 0.7s; }
  .d-particle:nth-child(3) { animation-delay: 1.4s; }
  .d-particle:nth-child(4) { animation-delay: 2.1s; }
  .d-particle:nth-child(5) { animation-delay: 2.8s; }
  .d-particle:nth-child(6) { animation-delay: 3.5s; }
  
  @keyframes floatParticle {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.6; }
    50% { transform: translate(15px, -20px) scale(1.3); opacity: 1; }
  }
  
  /* Water drops falling */
  .w-drop {
    animation: dropFall 2s ease-in infinite;
  }
  .w-drop:nth-child(1) { animation-delay: 0s; }
  .w-drop:nth-child(2) { animation-delay: 0.3s; }
  .w-drop:nth-child(3) { animation-delay: 0.6s; }
  .w-drop:nth-child(4) { animation-delay: 0.9s; }
  .w-drop:nth-child(5) { animation-delay: 1.2s; }
  .w-drop:nth-child(6) { animation-delay: 1.5s; }
  
  @keyframes dropFall {
    0% { transform: translateY(0); opacity: 1; }
    100% { transform: translateY(60px); opacity: 0; }
  }
  
  /* Nutrient bubbles floating away */
  .nutrient-bubble {
    animation: bubbleFloat 3s ease-in-out infinite;
  }
  .nb1 { animation-delay: 0s; }
  .nb2 { animation-delay: 0.8s; }
  .nb3 { animation-delay: 1.6s; }
  .nb4 { animation-delay: 2.4s; }
  
  @keyframes bubbleFloat {
    0%, 100% { transform: translate(0, 0); opacity: 0.8; }
    50% { transform: translate(-10px, -15px); opacity: 1; }
  }
  
  /* Shield pulse rings */
  .shield-pulse-ring {
    animation: shieldRingPulse 2s ease-out infinite;
    opacity: 0;
  }
  .spr1 { animation-delay: 0s; }
  .spr2 { animation-delay: 0.6s; }
  .spr3 { animation-delay: 1.2s; }
  
  @keyframes shieldRingPulse {
    0% { r: 70; opacity: 0.8; }
    100% { r: 130; opacity: 0; }
  }
  
  /* Orbit rings rotation */
  .orbit-ring {
    transform-origin: center;
  }
  .o1 { animation: orbitSpin 30s linear infinite; }
  .o2 { animation: orbitSpin 25s linear infinite reverse; }
  .o3 { animation: orbitSpin 20s linear infinite; }
  
  @keyframes orbitSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  /* Energy particles */
  .e-particle {
    animation: energyFloat 3s ease-in-out infinite;
  }
  .e-particle:nth-child(1) { animation-delay: 0s; }
  .e-particle:nth-child(2) { animation-delay: 0.5s; }
  .e-particle:nth-child(3) { animation-delay: 1s; }
  .e-particle:nth-child(4) { animation-delay: 1.5s; }
  .e-particle:nth-child(5) { animation-delay: 2s; }
  .e-particle:nth-child(6) { animation-delay: 2.5s; }
  
  @keyframes energyFloat {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.5); }
  }
  
  /* Energy rays pulsing */
  .e-ray {
    animation: rayPulse 2s ease-in-out infinite;
    opacity: 0.4;
  }
  .ray1 { animation-delay: 0s; }
  .ray2 { animation-delay: 0.25s; }
  .ray3 { animation-delay: 0.5s; }
  .ray4 { animation-delay: 0.75s; }
  .ray5 { animation-delay: 1s; }
  .ray6 { animation-delay: 1.25s; }
  .ray7 { animation-delay: 1.5s; }
  .ray8 { animation-delay: 1.75s; }
  
  @keyframes rayPulse {
    0%, 100% { opacity: 0.3; stroke-width: 3; }
    50% { opacity: 1; stroke-width: 6; }
  }
  
  /* Energy waves */
  .ew {
    animation: waveExpand 3s ease-out infinite;
    opacity: 0;
  }
  .ew:nth-child(1) { animation-delay: 0s; }
  .ew:nth-child(2) { animation-delay: 1s; }
  .ew:nth-child(3) { animation-delay: 2s; }
  
  @keyframes waveExpand {
    0% { r: 60; opacity: 0.8; }
    100% { r: 180; opacity: 0; }
  }
  
  /* Sparkles */
  .sparkle {
    animation: sparkleAnim 2s ease-in-out infinite;
  }
  .sparkle:nth-child(1) { animation-delay: 0s; }
  .sparkle:nth-child(2) { animation-delay: 0.3s; }
  .sparkle:nth-child(3) { animation-delay: 0.6s; }
  .sparkle:nth-child(4) { animation-delay: 0.9s; }
  .sparkle:nth-child(5) { animation-delay: 1.2s; }
  .sparkle:nth-child(6) { animation-delay: 1.5s; }
  
  @keyframes sparkleAnim {
    0%, 100% { opacity: 0; transform: scale(0); }
    50% { opacity: 1; transform: scale(1.5); }
  }
  
  /* Core rings */
  .core-ring {
    animation: coreRingSpin 8s linear infinite;
    transform-origin: center;
  }
  .cr2 { animation-direction: reverse; animation-duration: 6s; }
  
  @keyframes coreRingSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
