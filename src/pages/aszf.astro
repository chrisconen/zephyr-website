---
// aszf.astro - SALUTÉ Általános Szerződési Feltételek
// Statikus jogi oldal sticky tartalomjegyzékkel és PDF letöltéssel
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Tartalomjegyzék konfiguráció - az anchor linkekhez használjuk
const toc = [
  { id: 'szolgaltato-adatai', label: '1. Szolgáltató adatai' },
  { id: 'alapveto-rendelkezesek', label: '2. Alapvető rendelkezések' },
  { id: 'regisztracio-vasarlas', label: '3. Regisztráció / Vásárlás' },
  { id: 'termekek-arak', label: '4. Termékek, szolgáltatások, árak' },
  { id: 'rendeles-menete', label: '5. Rendelés menete' },
  { id: 'megrendelesek-feldolgozasa', label: '6. Megrendelések feldolgozása' },
  { id: 'elallas-joga', label: '7. Elállás joga' },
  { id: 'szavatossag', label: '8. Szavatosság' },
  { id: 'szavatossagi-igeny', label: '9. Szavatossági igény eljárás' },
  { id: 'vegyes-rendelkezesek', label: '10. Vegyes rendelkezések' },
  { id: 'panaszkezeles', label: '11. Panaszkezelés rendje' },
  { id: 'szerzoi-jogok', label: '12. Szerzői jogok' },
  { id: 'adatvedelem-link', label: '13. Adatvédelem' },
];
---

<Layout 
  title="Általános Szerződési Feltételek" 
  description="A Saluté (Toplexa Kft.) webshop általános szerződési feltételei. Hatályos: 2026. május 18-tól."
>
  
  <Header />
  
  <main class="legal-page">
    
    <!-- Hero szekció -->
    <section class="legal-hero">
      <div class="container">
        <span class="section-label">Jogi információk</span>
        <h1>Általános Szerződési Feltételek</h1>
        <p class="legal-meta">
          Toplexa Kft. · Hatályos: 2026. május 18-tól · Verzió 1.0
        </p>
        <a 
          href="/legal/SALUTÉ-aszf.pdf" 
          download="SALUTÉ_ASZF.pdf"
          class="pdf-download-btn"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          <span>PDF letöltése</span>
        </a>
      </div>
    </section>
    
    <!-- Tartalom + Sticky TOC -->
    <section class="legal-content-wrapper">
      <div class="container content-grid">
        
        <!-- Sticky tartalomjegyzék -->
        <aside class="toc-sidebar">
          <nav class="toc-nav" aria-label="Tartalomjegyzék">
            <h2 class="toc-title">Tartalom</h2>
            <ul class="toc-list">
              {toc.map(item => (
                <li><a href={`#${item.id}`}>{item.label}</a></li>
              ))}
            </ul>
          </nav>
        </aside>
        
        <!-- Fő tartalom -->
        <article class="legal-article">
          
          <div class="intro-block">
            <p>
              Jelen dokumentum alapján létrejött szerződés nem kerül iktatásra (utólag nem hozzáférhető, a szerződés megkötését a rendelési adatok bizonyítják), ráutaló magatartással tett jognyilatkozattal jön létre, nem minősül írásbeli szerződésnek, magyar nyelven íródik, magatartási kódexre nem utal. A webshop működésével, megrendelési és szállítási folyamatával kapcsolatosan felmerülő kérdések esetén a megadott elérhetőségeinken rendelkezésére állunk.
            </p>
            <p>
              Jelen ÁSZF hatálya Szolgáltató weblapján (<a href="https://SALUTÉhangover.com/">SALUTÉhangover.com</a>, <a href="https://SALUTÉhngvr.com/">SALUTÉhngvr.com</a>) és aldomainjein történő jogviszonyokra terjed ki. Jelen ÁSZF folyamatosan elérhető és letölthető a fenti PDF letöltése gombbal.
            </p>
            
            <div class="definitions-block">
              <h3>Definíciók</h3>
              <dl>
                <dt>Felhasználó</dt>
                <dd>Bármely természetes, jogi személy vagy szervezet, aki Szolgáltató szolgáltatásait igénybe veszi, Szolgáltatóval szerződést köt.</dd>
                
                <dt>Fogyasztó</dt>
                <dd>Olyan Felhasználó, aki a szakmája, önálló foglalkozása vagy üzleti tevékenysége körén kívül eljáró természetes személy.</dd>
                
                <dt>Vállalkozás</dt>
                <dd>A szakmája, önálló foglalkozása vagy üzleti tevékenysége körében eljáró személy.</dd>
                
                <dt>Szolgáltató</dt>
                <dd>Az információs társadalommal összefüggő szolgáltatást nyújtó természetes, illetve jogi személy vagy jogi személyiség nélküli szervezet, aki a Felhasználó részére szolgáltatást nyújt, aki a Felhasználóval szerződést köt.</dd>
              </dl>
            </div>
