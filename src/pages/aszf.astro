<script>
  // Vissza-az-elejére gomb + aktív TOC link kiemelés
  // Plain JS (Astro script tag-ben TypeScript szintaktika silent-failure-t okoz)
  
  var scrollTopBtn = document.getElementById('scrollTopBtn');
  var tocLinks = document.querySelectorAll('.toc-list a');
  var sections = document.querySelectorAll('.legal-section[id]');
  
  // Scroll-to-top gomb láthatóság + aktív szekció figyelése
  function handleScroll() {
    if (!scrollTopBtn) return;
    
    if (window.scrollY > 600) {
      scrollTopBtn.classList.add('visible');
    } else {
      scrollTopBtn.classList.remove('visible');
    }
    
    // Aktív TOC link megtalálása
    var currentSection = null;
    var scrollPos = window.scrollY + 150;
    
    for (var i = 0; i < sections.length; i++) {
      var section = sections[i];
      if (section && section.offsetTop <= scrollPos) {
        currentSection = section.id;
      }
    }
    
    if (currentSection) {
      tocLinks.forEach(function(link) {
        var href = link.getAttribute('href');
        if (href === '#' + currentSection) {
          link.classList.add('active');
        } else {
          link.classList.remove('active');
        }
      });
    }
  }
  
  if (scrollTopBtn) {
    scrollTopBtn.addEventListener('click', function() {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
  
  // Throttled scroll listener for performance
  var scrollTimer = null;
  window.addEventListener('scroll', function() {
    if (scrollTimer) return;
    scrollTimer = setTimeout(function() {
      handleScroll();
      scrollTimer = null;
    }, 100);
  });
  
  // Initial state check
  handleScroll();
</script>
